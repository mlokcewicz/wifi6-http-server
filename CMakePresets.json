{
    "version": 6,
    "cmakeMinimumRequired": {
      "major": 3,
      "minor": 23,
      "patch": 0
    },
    "configurePresets": [
      {
        "name": "base",
        "displayName": "base",
        "hidden": true,
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/build/",
        "cacheVariables": {
          "NCS_TOOLCHAIN_VERSION": "NONE",
          "BOARD": "custom_plank",
          "BOARD_ROOT": "${sourceDir}"
        }
      },
      {
        "name": "v1.0.0_debug",
        "inherits": "base",
        "displayName": "v1.0.0_debug",
        "description": "HW v1.0.0 Debug",
        "cacheVariables": {
            "BOARD": "custom_plank",
            "BOARD_REVISION": "1.0.0",
            "DCONF_FILE": "prj.conf;prj_debug.conf"
          }
      },
      {
        "name": "v1.0.0_release",
        "inherits": "base",
        "displayName": "v1.0.0_release",
        "description": "HW v1.0.0 Release",
        "cacheVariables": {
            "BOARD": "custom_plank",
            "BOARD_REVISION": "1.0.0",
            "DCONF_FILE": "prj.conf;prj_release.conf"
          }
      }
    ],
    "buildPresets": [
      {
        "name": "v1.0.0_debug",
        "configurePreset": "v1.0.0_debug",
        "targets": "all",
        "jobs": 0
      },
      {
        "name": "v1.0.0_release",
        "configurePreset": "v1.0.0_release",
        "targets": "all",
        "jobs": 0
      }
    ]
}
  