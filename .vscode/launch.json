    "version": "0.2.0",
    "configurations": [
        {
            "name": "debug",
            // Example:
            // D:\Inne\Links>mklink /D epn D:\Elektronika\Repozytoria\GitHub\firmware\firmware-core\templates\nrf52\wifi6-http-server
            "cwd": "${workspaceFolder}",
            // "cwd": "D:\\Inne\\Links\\epn",
            "executable": "build/v1.0.0_debug/whs/zephyr/zephyr.elf",
            "request": "launch",
            "type": "cortex-debug",
            "rtos": "Zephyr",
            "runToEntryPoint": "main",
            "servertype": "jlink",
            "svdFile": "C:/embedded_tools/ncs/v3.2.0/modules/hal/nordic/nrfx/bsp/stable/mdk/nrf5340.svd",
            "device": "nRF5340_xxAA_APP",
            // "preLaunchTask": "flash",
            "preLaunchCommands": [
                "monitor reset",
                "monitor halt"
            ],
            "rttConfig": {
                "enabled": true,                 
                "address": "auto",               
                "search": true,                  
                "polling_interval": 20,          
                "console": "integratedTerminal", 
                "decoders": [
                    {
                        "label": "RTT",          
                        "port": 0,               
                        "type": "console"        
                    }
                ]
            }
        },
        {
            "name": "attach",
            // Example:
            // D:\Inne\Links>mklink /D epn D:\Elektronika\Repozytoria\GitHub\firmware\firmware-core\templates\nrf52\wifi6-http-server
            "cwd": "${workspaceFolder}",
            // "cwd": "D:\\Inne\\Links\\epn",
            "executable": "build/v1.0.0_debug/whs/zephyr/zephyr.elf",
            "request": "attach",
            "type": "cortex-debug",
            "rtos": "Zephyr",
            "runToEntryPoint": "main",
            "servertype": "jlink",
            "svdFile": "C:/embedded_tools/ncs/v3.2.0/modules/hal/nordic/nrfx/bsp/stable/mdk/nrf5340.svd",
            "device": "nRF5340_xxAA_APP",
            "preLaunchTask": "flash",
            "preAttachCommands": [
                "monitor reset",
                "monitor halt"
            ],
            "rttConfig": {
                "enabled": true,                 
                "address": "auto",               
                "search": true,                  
                "polling_interval": 20,          
                "console": "integratedTerminal", 
                "decoders": [
                    {
                        "label": "RTT",          
                        "port": 0,               
                        "type": "console"        
                    }
                ]
            }
        }
    ]
