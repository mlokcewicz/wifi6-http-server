{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "options": {
        "env": {
            "ZEPHYR_SDK_INSTALL_DIR": "C:\\embedded_tools\\zephyr_sdk\\zephyr-sdk-0.17.4",
            "ZEPHYR_BASE": "C:\\embedded_tools\\ncs\\v3.2.2\\zephyr",
        },
        "cwd": "${workspaceFolder}"
        // Example:
        // D:\Inne\Links>mklink /D whs D:\Elektronika\Repozytoria\GitHub\firmware\wifi6-http-server
        // "cwd": "D:\\Inne\\Links\\whs"
    },
    "tasks": [
        {
            "label": "configure",
            "type": "process",
            "command": "west",
            "args": [
                "build",
                "--sysbuild",
                "--pristine",
                "--cmake-only",
                "-b", "nrf7002dk/nrf5340/cpuapp/ns",
                // "-b", "nrf7002dk/nrf5340/cpuapp",
                "-d", "build/v1.0.0_debug",
                "--",
                "-DHW_BOARD_REVISION=1.0.0",
                "-DBOARD_ROOT=${cwd}",
                // "-DCONF_FILE=prj.conf;prj_debug.conf"
            ]
        },
                {
            "label": "build pristine",
            "type": "process",
            "command": "west",
            "args": [
                "build",
                "--sysbuild",
                "--pristine",
                "-b", "nrf7002dk/nrf5340/cpuapp/ns",
                // "-b", "nrf7002dk/nrf5340/cpuapp",
                "-d", "build/v1.0.0_debug",
                "--",
                "-DHW_BOARD_REVISION=1.0.0",
                "-DBOARD_ROOT=${cwd}",
                // "-DCONF_FILE=prj.conf;prj_debug.conf"
            ]
        },
        {
            "label": "build",
            "type": "process",
            "command": "west",
            "args": [
                "build",
                "-d", "build/v1.0.0_debug",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "ram report",
            "type": "process",
            "command": "west",
            "args": [
                "build",
                "-d", "build/v1.0.0_debug",
                "-t", "ram_report"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "clean",
            "type": "process",
            "command": "west",
            "args": [
                "build",
                "-d", "build/v1.0.0_debug",
                "-t", "clean"
            ]
        },
        {
            "label": "flash",
            "type": "process",
            "command": "west",
            "args": [
                "flash",
                "-d", "build/v1.0.0_debug",
                "--runner", "jlink",
                "--speed", "14000",
                "--skip-rebuild"
            ]
            // Alternative 1 (plain west flash):
            // "type": "process",
            // "command": "west",
            // "args": [
            //     "flash"
            // "-d", "build/v1.0.0_debug",
            // ],
        },
        {
            "label": "recover",
            "type": "process",
            "command": "nrfutil",
            "args": [
                "device", "recover"
            ]
        }
    ]
}